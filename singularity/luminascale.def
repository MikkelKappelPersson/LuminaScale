Bootstrap: docker
From: pytorch/pytorch:2.10.0-cuda13.0-cudnn9-devel

%files
    pixi.toml /opt/pixi.toml
    pixi.lock /opt/pixi.lock

%post
    apt-get update && apt-get install -y \
        curl \
        ca-certificates \
        cmake \
        git \
        build-essential \
        libceres-dev \
        nlohmann-json3-dev \
        libopencv-dev \
        openimageio-tools \
        libopenimageio-dev \
        python3-pip

    # Install pixi
    curl -fsSL https://pixi.sh/install.sh | bash
    export PATH="/root/.pixi/bin:$PATH"

    # Create working directory and setup pixi environment
    mkdir -p /opt/project
    cd /opt/project
    cp /opt/pixi.toml ./pixi.toml
    if [ -f /opt/pixi.lock ]; then cp /opt/pixi.lock ./pixi.lock; fi

    # Install dependencies via pixi
    pixi install

    # Build and install rawtoaces with CUDA support (within pixi environment)
    cd /tmp
    git clone https://github.com/AcademySoftwareFoundation/rawtoaces.git
    cd rawtoaces
    pixi run cmake -S . -B build \
        -DCMAKE_CUDA_COMPILER=/usr/bin/nvcc \
        -DCUDA_TOOLKIT_ROOT_DIR=/usr/local/cuda
    pixi run cmake --build build
    pixi run cmake --install build
    cd /tmp && rm -rf rawtoaces

    # Clean up to reduce image size
    apt-get clean && rm -rf /var/lib/apt/lists/*

%environment
    export LC_ALL=C
    export PATH="/root/.pixi/bin:/opt/project/.pixi/envs/default/bin:$PATH"

%runscript
    exec bash "$@"

%test
    python -c "import torch; print(f'PyTorch {torch.__version__}'); print(f'CUDA available: {torch.cuda.is_available()}')"
    python -c "import hydra; print(f'Hydra available')"

%labels
    Author Mikkel Kappel Persson
    Version v0.2.0
    Project LuminaScale
    Description "Neural Bit-Depth Expansion & ACES Color Space Normalization"

%help
    LuminaScale: Neural Bit-Depth Expansion & ACES Color Space Normalization

    A containerized research environment for training and evaluating neural models
    that expand bit-depth and normalize color to ACES working space.

    Usage:
      singularity exec luminascale.sif python -c "print('hello world')"
      singularity exec --nv luminascale.sif python scripts/train.py
      srun singularity exec --nv luminascale.sif python scripts/train.py
