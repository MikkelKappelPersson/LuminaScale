Bootstrap: docker
From: pytorch/pytorch:2.10.0-cuda13.0-cudnn9-devel

%post
    apt-get update && apt-get install -y python3-venv

    # Create and activate virtual environment
    python3 -m venv /opt/venv

    # Use the venv Python for all subsequent installations
    . /opt/venv/bin/activate

    # Upgrade pip/setuptools first
    pip install --no-cache-dir --upgrade pip setuptools wheel

    # Install Python dependencies
    pip install --no-cache-dir \
        hydra-core \
        omegaconf \
        scikit-image \
        imageio \
        numpy \
        tensorboard \
        tqdm \
        torch  # PyTorch should be available from base image but ensure it's in venv

    # Create working directory
    mkdir -p /work

%environment
    export LC_ALL=C
    export PATH=/opt/venv/bin:$PATH

%runscript
    exec bash "$@"

%test
    python -c "import torch; print(f'PyTorch {torch.__version__}'); print(f'CUDA available: {torch.cuda.is_available()}')"
    python -c "import hydra; print(f'Hydra version: {hydra.__version__}')"

%labels
    Author Mikkel Kappel Persson
    Version v0.1.0
    Project LuminaScale
    Description "Neural Bit-Depth Expansion & ACES Color Space Normalization"

%help
    LuminaScale: Neural Bit-Depth Expansion & ACES Color Space Normalization

    A containerized research environment for training and evaluating neural models
    that expand bit-depth and normalize color to ACES working space.

    Usage:
      singularity exec luminascale.sif python scripts/train.py
      singularity exec --nv luminascale.sif python scripts/train.py training=hpc_slurm
