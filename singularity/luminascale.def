Bootstrap: docker
From: pytorch/pytorch:2.10.0-cuda12.8-cudnn9-devel

%post
    apt-get update && apt-get install -y \
        curl \
        ca-certificates \
        cmake \
        git \
        build-essential \
        exiftool \
        libeigen3-dev \
        libceres-dev \
        nlohmann-json3-dev \
        libopencv-dev \
        openimageio-tools \
        libopenimageio-dev \
        liblensfun-dev \
        libglib2.0-dev \
        libtiff-dev \
        libpng-dev \
        python3-venv

    # Create Python virtual environment with system packages (PyTorch from base image)
    python3 -m venv /opt/venv --system-site-packages
    
    # Activate venv and install dependencies
    . /opt/venv/bin/activate
    pip install --upgrade pip wheel
    pip install --no-cache-dir "setuptools==81.*"
    pip install --no-cache-dir \
        pytest \
        pytest-cov \
        hydra-core \
        omegaconf \
        scikit-image \
        imageio \
        tensorboard \
        tqdm \
        matplotlib \
        jupyter \
        scipy \
        numpy \
        nanobind \
        openimageio \
        opencolorio \
        opencv-python \
        pyopengl \
        pyopengl-accelerate \
        torchvision \
        pandas \
        webdataset \
        fastparquet \
        pyarrow \
        pillow \
        pytorch-lightning \


    # Build and install rawtoaces (CPU-based, no CUDA support needed)
    cd /tmp
    git clone https://github.com/AcademySoftwareFoundation/rawtoaces.git
    cd rawtoaces
    cmake -S . -B build
    cmake --build build -j$(nproc)
    cmake --install build
    cd /tmp && rm -rf rawtoaces

    # Create working directory
    mkdir -p /opt/project

    # Clean up to reduce image size
    apt-get clean && rm -rf /var/lib/apt/lists/*

%environment
    export LC_ALL=C
    export PYTHONUNBUFFERED=1
    export PATH="/opt/venv/bin:${PATH}"
    export VIRTUAL_ENV="/opt/venv"

%runscript
    exec bash "$@"

%test
    python -c "import torch; print(f'PyTorch {torch.__version__}'); print(f'CUDA available: {torch.cuda.is_available()}')"
    python -c "import hydra; print('Hydra available')"
    rawtoaces --version
    python -c "import sys; print(f'Python: {sys.executable}')"

%labels
    Author Mikkel Kappel Persson
    Version v0.2.0
    Project LuminaScale
    Description "Neural Bit-Depth Expansion & ACES Color Space Normalization"

%help
    LuminaScale: Neural Bit-Depth Expansion & ACES Color Space Normalization

    A containerized research environment for training and evaluating neural models
    that expand bit-depth and normalize color to ACES working space.

    Pre-installed packages: PyTorch 2.10, CUDA 12.8, Hydra, SciPy, rawtoaces, and more
    Python venv: /opt/venv (activated by default)

    Quick start:
      srun singularity exec --nv luminascale.sif python scripts/train.py
      srun singularity exec luminascale.sif python -c "import torch; print(torch.cuda.is_available())"
    
    Install additional packages (creates/updates local venv):
      srun singularity exec luminascale.sif pip install new-package
    
    Interactive shell:
      srun singularity shell --nv luminascale.sif
